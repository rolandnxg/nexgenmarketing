# The crew-service shares the dashboard's .env (bind-mounted by docker-compose).
# Only these keys are relevant to the crew; they already live in the dashboard .env.

# OpenAI — powers the CrewAI agents (decided: keep OpenAI / GPT-4.1).
OPENAI_API_KEY=sk-YOUR_KEY_HERE
OPENAI_MODEL=gpt-4.1
OPENAI_TEMPERATURE=0.3

# Where the crew calls back for live Google Ads / GA4 data (the Node app).
# Inside docker-compose this is the marketiq service name.
DASHBOARD_API_URL=http://marketiq:3000
DASHBOARD_API_TIMEOUT=30
