OPENAI_API_KEY=sk-YOUR_KEY_HERE
# Model used by the CrewAI chat service (and the OpenAI fallback).
OPENAI_MODEL=gpt-4.1

# AI chat backend. When set, /api/ai-chat proxies to the CrewAI sidecar
# (docker-compose sets this automatically); if it is unset or unreachable the
# dashboard falls back to a direct OpenAI call. Leave blank for local non-Docker runs.
CREW_SERVICE_URL=

GADS_CUSTOMER_IDS=ID1,ID2,ID3
GADS_DEVELOPER_TOKEN=YOUR_DEVELOPER_TOKEN
GADS_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GADS_CLIENT_SECRET=YOUR_CLIENT_SECRET
GADS_REFRESH_TOKEN=YOUR_REFRESH_TOKEN

FB_ACCOUNT_ID=act_XXXXXXXXXXXXXXXXX
FB_ACCESS_TOKEN=YOUR_FB_ACCESS_TOKEN

GA_PROPERTY_ID=YOUR_GA4_PROPERTY_ID
GA_REFRESH_TOKEN=YOUR_GA_REFRESH_TOKEN

# Optional: folder where another agent writes markdown reports.
# Docker mounts this folder read-only and the dashboard reads the newest .md file.
AGENT_MARKDOWN_HOST_DIR=C:/Users/YourName/Developer/your-agent-output-folder
AGENT_MARKDOWN_PATH=
